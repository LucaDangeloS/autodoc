// App Shared Variables
// --------------------------------------------------
// Slate-based color system inspired by modern UI frameworks (Tailwind slate scale).

// App Shared Color Variables
// --------------------------------------------------

$primary   = #3c4759
$secondary = #26A69A
$tertiary  = #555

$neutral   = #E0E1E2
$positive  = #21BA45
$negative  = #DB2828
$info      = #31CCEC
$warning   = #F2C037

// Additional colors for login background
$blue      = #4a5d82

// Edit button color
$blueEditBtn = #1976d2

// CSS class for edit buttons
.edit-btn-color
  color $blueEditBtn !important

$item-font-size = 14px
$input-font-size = 14px
$typography-font-family = Helvetica, Arial, sans-serif

.q-input-target
    font-size 14px!important

// ── Slate palette ──────────────────────────────────
$slate50  = #f8fafc
$slate100 = #f1f5f9
$slate200 = #e2e8f0
$slate300 = #cbd5e1
$slate400 = #94a3b8
$slate500 = #64748b
$slate600 = #475569
$slate700 = #334155
$slate800 = #1e293b
$slate900 = #0f172a

// Diff colors
$diffBackground     = #fee2e2
$diffBackgroundDark = #f4433626

$diffTextNegative = #fdb8c0

// Dark-mode tokens
$cDark       = $slate900
$darkPrimary = #a5b4fc   // indigo-300
$darkHeader  = $slate700
$darkSurface = $slate800
$darkInput   = $slate800

// ── Toggle accent ──────────────────────────────────
$toggleAccent = $secondary

.q-toggle__inner--truthy
    .q-toggle__thumb
        color: $toggleAccent !important
    .q-toggle__track
        background: rgba($toggleAccent, 0.38) !important

// Light-mode off state
.q-toggle__inner--falsy
    .q-toggle__thumb
        color: $slate400 !important
    .q-toggle__track
        background: $slate300 !important

// Dark-mode off state — bright enough to see on any dark surface
.body--dark .q-toggle__inner--falsy
    .q-toggle__thumb
        color: $slate400 !important
    .q-toggle__track
        background: $slate600 !important

// ── Border-radius tokens ───────────────────────────
$radius-sm  = 6px
$radius-md  = 10px
$radius-lg  = 14px

// ── Global border-radius overrides ─────────────────
.q-card
    border-radius $radius-lg !important

.q-dialog .q-card
    border-radius $radius-lg !important

.q-field--outlined .q-field__control
    border-radius $radius-md !important

.q-btn
    border-radius $radius-sm !important

.q-table__container
    border-radius $radius-lg !important
    overflow hidden

.q-chip
    border-radius $radius-sm !important

// [Fix #4] Tabs: pill-shaped with all corners rounded
.q-tab
    border-radius $radius-sm !important

.q-toggle__inner
    border-radius 999px

.q-expansion-item__container
    border-radius $radius-md !important
    overflow hidden

.q-menu
    border-radius $radius-md !important

.q-notification
    border-radius $radius-md !important

// [Fix #3] Color picker inputs: rounded, no white border, consistent sizing
input[type="color"]
    -webkit-appearance: none
    -moz-appearance: none
    appearance: none
    border: 2px solid $slate300
    border-radius: $radius-sm
    width: 40px
    height: 40px
    padding: 2px
    cursor: pointer
    background: transparent

    &::-webkit-color-swatch-wrapper
        padding: 0

    &::-webkit-color-swatch
        border: none
        border-radius: 4px

    &::-moz-color-swatch
        border: none
        border-radius: 4px

    &:disabled
        opacity: 0.4
        cursor: not-allowed

// [Fix #5] Editor toolbar: inherit container's top border-radius
.q-card.editor
    overflow hidden

    .editor-toolbar
        border-radius: ($radius-lg - 1) ($radius-lg - 1) 0 0

// ── Light mode ─────────────────────────────────────
light-mode-colors()

    .bg-diffbackground
        background: $diffBackground!important
    .diffbackground-text
        color: $diffBackground

    .q-field:not(.basic-editor) .q-field__control,
    .editor
        background white

    .q-card:not(.editor):not(.cvsscalculator),
    .q-table__container
        background $slate50

    // [Fix #7] Unified table backgrounds in light mode
    .q-table__top,
    .q-table__container thead tr
        background: $slate50

    // Hack for white text on white bg in q-btn elements
    .q-btn.bg-white.text-white
        color: #000000!important

    // Slate-tinted section headers (replaces Quasar blue-grey)
    .bg-blue-grey-5
        background: $slate600!important
    .bg-blue-grey-2
        background: $slate200!important
    .bg-grey-4
        background: $slate200!important
    .bg-grey-3
        background: $slate100!important


// ── Dark mode ──────────────────────────────────────
$darkBorder = rgba($slate400, 0.18)

dark-mode-colors()
    // Replace shadows with subtle borders on elevated components
    .q-card,
    .q-table__container,
    .q-menu,
    .q-dialog .q-card,
    .q-notification
        box-shadow: none !important
        border: 1px solid $darkBorder

    .q-separator
        background: $darkBorder !important

    // Diff background color
    .bg-diffbackground
        background: $diffBackgroundDark!important
    .diffbackground-text
        color: $diffBackgroundDark

    .bg-white
        background: $cDark!important
    .bg-blue-grey-5
        background: $darkHeader!important
    .bg-blue-grey-2,
    .bg-grey-4,
    .bg-grey-3
        background: $darkSurface!important

    .bg-light-blue-2
        background: #03a9f418!important
    .bg-orange-2
        background: #ff980018!important

    .text-grey-8
        color: $slate400!important

    --q-color-primary: $darkPrimary

    // [Fix #7] Unified table backgrounds in dark mode — same color everywhere
    .q-table__top,
    .q-table__container thead tr
        background: $darkSurface

    .q-field:not(.basic-editor) .q-field__control,
    .expansion-header
    .editor
        background $darkInput!important

    .editor p code
        background: $slate700
        color: $slate200

    .diffrem
        background-color: #a03936
    pre .diffrem
        background-color: #f44336

    .diffadd
        background-color: #1d572d
    pre .diffadd
        background-color: #4caf50

    .login-form
        background: white

    // [Fix #3] Color picker dark-mode border
    input[type="color"]
        border-color: $slate600

    // [Fix #5] Editor toolbar dark background
    .editor-toolbar
        background: $darkSurface

// ── Common colors (theme-agnostic) ─────────────────
common-colors()
    .bg-fixed-primary
        background: $primary
    .text-fixed-primary
        color: $primary

// ── Apply themes ───────────────────────────────────
.body--dark {
    common-colors()
    dark-mode-colors()
}

.body--light {
    common-colors()
    light-mode-colors()
}

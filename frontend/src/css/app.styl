.home-drawer .q-router-link--active {
    background-color: $primary;
    opacity: 0.9;
    color: white!important;
}

.chip-center .q-chip-main {
    margin: auto;
}

// Make one line for each chip (for example in q-select)
.q-chip-one-line .q-chip {
    margin-right: 100%;
}

.dropzone {
    border: dashed;
    border-color: $blue;
    border-width: 2px;
    border-radius: 5px;
    height: 50px!important;
    color: $grey-8;
}

.vertical-center {
  margin: 0;
  position: absolute;
  top: 50%;
  -ms-transform: translateY(-50%);
  transform: translateY(-50%);
}

// For handling \n and tabs
.text-pre-wrap {
    white-space: pre-wrap;
}

.sticky-header-table
    /* height or max-height is important */
    max-height: calc(100vh - 82px)

    thead tr:first-child th
        border-bottom: 0

    thead tr:first-child th
        position: sticky
        z-index: 1
        top: 0

    /* this is when the loading indicator appears */
    &.q-table--loading thead tr:last-child th
        z-index: 2

    tr
        cursor: initial !important

    /* Sticky action column — always visible on the right */
    th:last-child,
    td:last-child
        position: sticky
        right: 0
        z-index: 1

.sticky-header-table-addfinding
    /* height or max-height is important */
    max-height: calc(100vh - 132px)

    thead tr:first-child th
        border-bottom: 0
        // border-bottom: 1px solid rgba(0,0,0,0.12)
    
    thead tr:first-child th
        position: sticky
        z-index: 1
        top: 0

    /* this is when the loading indicator appears */
    &.q-table--loading thead tr:last-child th
        z-index: 2

    tr
        cursor: initial !important

.loading-error .material-icons {
    font-size: 100px;
}

.loading-error p {
    font-size: 20px;
}

.loading-error:before {
    opacity: 0.7;
}

// ── Global page content side margins on mobile ─────
// Quasar xs breakpoint is < 600px, sm is 600–1023px
@media (max-width: 1023px)
    .q-page-container .row > .col-12
        padding-left: 12px
        padding-right: 12px

// ── Settings page scroll offset for sticky header ──
[id^="section-"]
    scroll-margin-top: 16px

// ── Settings page side navigation ──────────────────
.settings-nav
    position: sticky
    top: 70px

    .q-item
        border-radius: 0 8px 8px 0
        min-height: 36px
        padding: 4px 12px
        margin-bottom: 2px
        border-left: 3px solid transparent
        transition: all 0.15s ease

.settings-nav-active
    border-left-color: $secondary !important
    background: rgba($secondary, 0.08) !important
    color: $secondary !important
    .q-item__label,
    .q-item-label
        color: $secondary !important
        font-weight: 600

.body--dark .settings-nav-active
    background: rgba($secondary, 0.15) !important
    color: #5eeadb !important
    .q-item__label,
    .q-item-label
        color: #5eeadb !important

// ── Dark mode overrides ─────────────────────────────
// Custom fields preview area uses bg-grey-2 which is light in dark mode
.body--dark .bg-grey-2
    background-color: $slate700 !important

// Tab bars with hardcoded bg-white class
.body--dark .q-tabs.bg-white
    background-color: $slate800 !important

// CVSS calculator cards — the q-card bg-grey-1 class used in finding edit
.body--dark .bg-grey-1
    background-color: $slate800 !important

// ── AI loading animation ────────────────────────────
@keyframes ai-pulse
    0%, 100%
        opacity: 0.4
    50%
        opacity: 1

p.ai-loading
    color: $secondary
    font-style: italic
    animation: ai-pulse 1.2s ease-in-out infinite

    &::before
        content: '✦ '
        font-style: normal